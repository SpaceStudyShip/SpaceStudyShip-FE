{
  "openapi": "3.1.0",
  "info": {
    "title": "우주공부선 API",
    "description": "우주공부선 백엔드 API 문서입니다.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "백엔드주소",
      "description": "Production"
    },
    {
      "url": "http://localhost:8080",
      "description": "Local"
    }
  ],
  "security": [
    {
      "JWT": []
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "소셜 로그인 및 토큰 관리 API"
    }
  ],
  "paths": {
    "/api/auth/reissue": {
      "post": {
        "tags": ["Auth"],
        "summary": "토큰 재발급",
        "operationId": "reissue",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReissueRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ReissueResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "operationId": "logout",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogoutRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "소셜 로그인",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ReissueRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": ["refreshToken"]
      },
      "ReissueResponse": {
        "type": "object",
        "properties": {
          "tokens": {
            "$ref": "#/components/schemas/Tokens"
          }
        }
      },
      "Tokens": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "LogoutRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "required": ["refreshToken"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "socialType": {
            "type": "string",
            "enum": ["KAKAO", "GOOGLE", "APPLE"]
          },
          "idToken": {
            "type": "string"
          }
        },
        "required": ["idToken", "socialType"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "memberId": {
            "type": "integer",
            "format": "int64"
          },
          "nickname": {
            "type": "string"
          },
          "tokens": {
            "$ref": "#/components/schemas/Tokens"
          },
          "isNewMember": {
            "type": "boolean"
          }
        }
      }
    },
    "securitySchemes": {
      "JWT": {
        "type": "http",
        "description": "JWT Access Token을 입력하세요. 'Bearer ' 접두사는 자동으로 추가됩니다.",
        "name": "JWT",
        "scheme": "bearer"
      }
    }
  }
}
